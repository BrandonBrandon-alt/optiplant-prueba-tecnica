# =========================================================================
# SEGURIDAD — Variables de entorno y certificados
# =========================================================================
# NUNCA subir credenciales ni secretos al repositorio
.env
.env.*
*.pem
*.p12
*.jks

# =========================================================================
# Sistema operativo
# =========================================================================
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini

# =========================================================================
# IDEs y Editores
# =========================================================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# VS Code (configuracion local de editor, no del proyecto)
.vscode/

# Spring Tool Suite / Eclipse
.sts4-cache
.project
.classpath
.settings/
.factorypath
.apt_generated/
.springBeans

# =========================================================================
# BACKEND — Spring Boot / Java / Maven
# =========================================================================
# Compilados de Maven (SOLO la carpeta target del backend)
backend/target/

# Wrapper de Maven — MANTENER para portabilidad del proyecto
!backend/.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.jar

# Artefactos empaquetados — nunca subir binarios compilados
*.jar
*.war
!**/maven-wrapper.jar

# Logs de la aplicación
*.log
*.log.*

# =========================================================================
# FRONTEND — Next.js / Node.js
# =========================================================================
# Dependencias — nunca subir node_modules (se reinstalan con npm install)
frontend/node_modules/

# Archivos de build y caché de Next.js
frontend/.next/
frontend/out/
frontend/build/

# Configuracion de despliegue en Vercel (entorno local)
frontend/.vercel/

# Archivos generados por TypeScript y Next.js
frontend/*.tsbuildinfo
frontend/**/*.tsbuildinfo
frontend/next-env.d.ts

# Archivos de Yarn (si se usa Yarn en lugar de npm)
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# Cobertura de tests del frontend
frontend/coverage/

# Logs de gestores de paquetes
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*